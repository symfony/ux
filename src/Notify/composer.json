{
    "name": "symfony/ux-notify",
    "type": "symfony-bundle",
    "description": "Notification integration for Symfony",
    "keywords": [
        "symfony",
        "ux",
        "notification"
    ],
    "homepage": "https://symfony.com",
    "license": "MIT",
    "authors": [
        {
            "name": "Mathias Arlaud",
            "email": "mathias.arlaud@gmail.com"
        },
        {
            "name": "Symfony Community",
            "homepage": "https://symfony.com/contributors"
        }
    ],
    "autoload": {
        "psr-4": {
            "Symfony\\UX\\Notify\\": "."
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Symfony\\UX\\Notify\\": "./Tests"
        }
    },
    "require": {
        "php": ">=7.2.5",
        "symfony/config": "^4.4.17|^5.0",
        "symfony/dependency-injection": "^4.4.17|^5.0",
        "symfony/http-kernel": "^4.4.17|^5.0",
        "symfony/mercure-bundle": "^0.2.7",
        "symfony/mercure-notifier": "^5.3",
        "symfony/notifier": "^4.4.17|^5.0",
        "symfony/polyfill-php80": "^1.15"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.5",
        "symfony/framework-bundle": "^4.4.17|^5.0",
        "symfony/twig-bundle": "^4.4.17|^5.0",
        "symfony/var-dumper": "^4.4.17|^5.0"
    },
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    }
}
